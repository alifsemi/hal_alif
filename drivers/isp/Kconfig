config USE_ALIF_ISP_LIB
	bool "Enable ISP Middleware for Alif SoC"
	depends on VIDEO_ISP_VSI
	select FPU

if USE_ALIF_ISP_LIB

config ISP_LIB_SCALAR_MODULE
	bool "Enable Scalar module in ISP library"
	default n
	help
	 Select the Scalar module in Vivante ISP Nano for Alif SoCs.

config ISP_LIB_AE_MODULE
	bool "Enable Auto Exposure module in ISP library"
	default n
	help
	 Select the AE module in Vivante ISP Nano for Alif SoCs.

config ISP_LIB_WB_MODULE
	bool "Enable White Balancing module in ISP library"
	default n
	help
	 Select the White Balancing module in Vivante ISP Nano
	 for Alif SoCs.

config ISP_LIB_BINNING_MODULE
	bool "Enable Binning module in ISP library"
	default n
	help
	 Select the Binning module in Vivante ISP Nano for Alif SoCs.

config ISP_LIB_BLS_MODULE
	bool "Enable Black Level Subtraction module in ISP library"
	default n
	help
	 Select the Black Level Subtraction module in Vivante ISP Nano
	 for Alif SoCs.

config ISP_LIB_DMSC_MODULE
	bool "Enable Demosaic module in ISP library"
	default n
	help
	 Select the Demosaic module in Vivante ISP Nano for Alif SoCs.

config ISP_LIB_FLT_MODULE
	bool "Enable Filter module in ISP library"
	default n
	help
	 Select the Filter module in Vivante ISP Nano for Alif SoCs.

config ISP_LIB_CCM_MODULE
	bool "Enable Color Correction Matrix module in ISP library"
	default n
	help
	 Select the CCM module in Vivante ISP Nano for Alif SoCs.

config ISP_LIB_GAMMAOUT_MODULE
	bool "Enable Gamma correction module in ISP library"
	default n
	help
	 Select the Gamma correction module in Vivante ISP Nano for Alif SoCs.

config ISP_LIB_EXPOSUREM_MODULE
	bool "Enable Exposure Measurement module in ISP library"
	default n
	help
	 Select the Exposure measurement module in Vivante ISP Nano for
	 Alif SoCs.

config ISP_LIB_CSM_MODULE
	bool "Enable Color Space Matrix module in ISP library"
	default n
	help
	 Select the Color Space Matrix module in Vivante ISP Nano for
	 Alif SoCs.

config ISP_LIB_WBM_MODULE
	bool "Enable White Balancing Measurement module in ISP library"
	default n
	help
	 Select the White Balancing measurement module in Vivante ISP Nano for
	 Alif SoCs.

config ISP_SENSOR_OV5675
	bool "OV5675 sensor ISP parameters"
	depends on VIDEO_OV5675
	default y if VIDEO_OV5675
	help
	  Compile OV5675-specific ISP calibration parameters and sensor
	  attributes (ov5675_isp_param_conf.c, ov5675_sensor_attributes.c)
	  when the OV5675 sensor is connected to the ISP pipeline.

config ISP_SENSOR_ARX3A0
	bool "ARX3A0 sensor ISP parameters"
	depends on VIDEO_ARX3A0
	default y if VIDEO_ARX3A0
	help
	  Compile ARX3A0-specific ISP calibration parameters and sensor
	  attributes (arx3a0_isp_param_conf.c, arx3a0_sensor_attributes.c)
	  when the ARX3A0 sensor is connected to the ISP pipeline.

endif # USE_ALIF_ISP_LIB
